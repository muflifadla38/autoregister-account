  "type": "commonjs",
  "dependencies": {
    "2captcha": "^3.0.5-2",
    "openai": "^6.44.0",
    "playwright": "^1.61.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "recaptcha-solver": "^0.3.0",
    "tesseract.js": "^5.1.1"
  }
}
