{
  "name": "xiaomi-mimo-autoreg",
  "version": "1.0.0",
  "description": "Auto register accounts on Xiaomi MiMo API Open Platform using Playwright + TempMail",
  "main": "register.js",
  "scripts": {
    "register": "node register.js",
    "xiaomi": "node register.js xiaomi",
    "alibaba": "node register.js alibaba",
    "qoder": "node register.js qoder",
    "loop": "node loop.js",
    "loop-xiaomi": "node loop.js xiaomi",
    "tempmail": "node tempmail.js",
    "check-proxies": "node check-proxies.js",
    "recheck-proxies": "node recheck-proxies.js",
    "proxies": "node check-proxies.js && node recheck-proxies.js",
    "extract-keys": "node extract-keys.js",
    "playwright:install": "npx playwright install chromium"
  },
  "keywords": [
    "automation",
    "playwright",
    "tempmail",
    "xiaomi"
  ],
  "author": "",
